CONFIG_DRIVER_NL80211=y

# pkg-config yerine kendi derlediğimiz yolları veriyoruz
CFLAGS += -I/home/yusuf/y2-os/src/libnl_static/include/libnl3
LIBS += -L/home/yusuf/y2-os/src/libnl_static/lib -lnl-genl-3 -lnl-3

CONFIG_TLS=internal
CONFIG_INTERNAL_LIBTOMMATH=y
CONFIG_INTERNAL_AES=y
CONFIG_INTERNAL_SHA1=y
CONFIG_INTERNAL_SHA256=y
CONFIG_INTERNAL_MD5=y
CONFIG_INTERNAL_RC4=y
CONFIG_INTERNAL_DES=y

CONFIG_NO_RANDOM_POOL=y
CONFIG_CTRL_IFACE=y
